rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isAdminOrManager() {
      return isAdmin() || hasRole('manager');
    }

    // ── System config (admin setup lock, etc.) ───────────────
    // Only the Admin SDK (backend) can write; admins may read.
    match /systemConfig/{doc} {
      allow read: if isAdmin();
      allow write: if false; // Admin SDK bypasses rules
    }

    // ── Users collection ─────────────────────────────────────
    match /users/{userId} {
      // A user can read their own document; admins & managers can read all.
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdminOrManager());
      // Only admins can create or modify user documents through the client.
      // In practice all writes go through the Admin SDK (backend).
      allow write: if isAdmin();
    }

    // ── All other collections (donors, pickups, etc.) ────────
    // Access is controlled by the Express backend via Admin SDK,
    // so direct Firestore client access is denied.
    // If you ever expose Firestore directly to the frontend,
    // add per-collection rules here.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
