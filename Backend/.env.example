# Use one of these Admin SDK credential options:
# 1. Recommended on Google/Firebase infrastructure: Application Default Credentials.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
#
# 2. For local/dev secrets managers: base64-encoded JSON service account.
# FIREBASE_SERVICE_ACCOUNT_BASE64=
#
# 3. Individual service-account fields.
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Signed URL defaults
SIGNED_URL_TTL_MINUTES=15
MAX_UPLOAD_MB=8

